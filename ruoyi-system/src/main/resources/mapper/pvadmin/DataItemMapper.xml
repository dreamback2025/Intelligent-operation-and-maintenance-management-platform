<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.pvadmin.mapper.DataItemMapper">

    <select id="listDataItemByDeviceIds" resultType="com.ruoyi.pvadmin.domain.entity.DataItem">
        SELECT
            device_id,
            time_code,
            time_type,
            data_time,
            `value`
        FROM
            data_item
        WHERE
            device_id IN
        <foreach collection="deviceIds" item="deviceId" open="(" separator="," close=")">
            #{deviceId}
        </foreach>
        AND time_type = #{timeType}
        AND (data_time BETWEEN #{beginTime} AND #{endTime})
    </select>

</mapper>